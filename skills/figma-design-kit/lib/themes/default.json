{
  "name": "Default Dark",
  "description": "Standard dark theme for tech/SaaS design. Blue-teal accent palette.",

  "colors": {
    "BG":      { "r": 0.05,  "g": 0.06,  "b": 0.09  },
    "CARD":    { "r": 0.086, "g": 0.10,  "b": 0.145 },
    "WT":      { "r": 0.96,  "g": 0.97,  "b": 0.98  },
    "BD":      { "r": 0.78,  "g": 0.81,  "b": 0.85  },
    "MT":      { "r": 0.45,  "g": 0.48,  "b": 0.55  },
    "BL":      { "r": 0.20,  "g": 0.40,  "b": 1.00  },
    "TL":      { "r": 0.08,  "g": 0.72,  "b": 0.65  },
    "STK":     { "r": 0.14,  "g": 0.16,  "b": 0.22  },
    "WARN":    { "r": 1.00,  "g": 0.60,  "b": 0.20  },
    "ERR":     { "r": 1.00,  "g": 0.35,  "b": 0.35  },
    "SUCCESS": { "r": 0.20,  "g": 0.80,  "b": 0.50  }
  },

  "type": {
    "h1":    { "fontSize": 72, "style": "Bold",      "lineHeight": 86 },
    "h2":    { "fontSize": 48, "style": "Bold",      "lineHeight": 58 },
    "h3":    { "fontSize": 32, "style": "Semi Bold", "lineHeight": 40 },
    "h4":    { "fontSize": 22, "style": "Semi Bold", "lineHeight": 30 },
    "body":  { "fontSize": 16, "style": "Regular",   "lineHeight": 26 },
    "small": { "fontSize": 13, "style": "Regular",   "lineHeight": 20 },
    "label": { "fontSize": 11, "style": "Medium",    "lineHeight": null },
    "mono":  { "fontSize": 11, "style": "Medium",    "lineHeight": null, "family": "Geist Mono" }
  },

  "fonts": {
    "heading": "Inter",
    "body":    "Inter",
    "mono":    "Geist Mono",
    "weights": ["Bold", "Semi Bold", "Medium", "Regular", "Light"]
  },

  "effects": {
    "glass": {
      "subtle":  { "r": 16, "f": 0.03, "s": 0.06, "ga": 0.04, "bl": 20 },
      "default": { "r": 20, "f": 0.04, "s": 0.08, "ga": 0.06, "bl": 24 },
      "strong":  { "r": 24, "f": 0.06, "s": 0.12, "ga": 0.12, "bl": 24 },
      "pill":    { "r": 20, "f": 0.06, "s": 0.10, "ga": 0.06, "bl": 20 }
    },
    "shadow": {
      "card":  { "type": "DROP_SHADOW", "color": { "r": 0.08, "g": 0.12, "b": 0.20, "a": 0.08 }, "offset": { "x": 0, "y": 2 }, "radius": 16, "spread": 0, "visible": true, "blendMode": "NORMAL" },
      "glow":  { "type": "DROP_SHADOW", "color": { "r": 0.20, "g": 0.40, "b": 1.00, "a": 0.12 }, "offset": { "x": 0, "y": 4 }, "radius": 24, "spread": 0, "visible": true, "blendMode": "NORMAL" },
      "strong":{ "type": "DROP_SHADOW", "color": { "r": 0.20, "g": 0.40, "b": 1.00, "a": 0.22 }, "offset": { "x": 0, "y": 6 }, "radius": 28, "spread": 0, "visible": true, "blendMode": "NORMAL" }
    }
  },

  "spacing": {
    "page":    { "padding": 80, "gap": 16 },
    "card":    { "padding": 24, "gap": 12 },
    "slide":   { "width": 1080, "height": 1350, "padding": 80 },
    "frame16": { "width": 1920, "height": 1080 },
    "letter":  { "width": 1224, "height": 1584, "margin": 60 }
  },

  "gradients": {
    "accent": {
      "type": "GRADIENT_LINEAR",
      "gradientTransform": [[1,0,0],[0,1,0]],
      "gradientStops": [
        { "position": 0, "color": { "r": 0.20, "g": 0.40, "b": 1.00, "a": 1 } },
        { "position": 1, "color": { "r": 0.08, "g": 0.72, "b": 0.65, "a": 1 } }
      ]
    },
    "cta": {
      "type": "GRADIENT_LINEAR",
      "gradientTransform": [[1,0,0],[0,1,0]],
      "gradientStops": [
        { "position": 0, "color": { "r": 0.15, "g": 0.32, "b": 0.92, "a": 1 } },
        { "position": 1, "color": { "r": 0.06, "g": 0.50, "b": 0.60, "a": 1 } }
      ]
    }
  }
}
