{
  "name": "Light",
  "description": "Light-mode theme for print-friendly deliverables. White cards on grey.",

  "colors": {
    "BG":      { "r": 0.945, "g": 0.949, "b": 0.957 },
    "CARD":    { "r": 1.00,  "g": 1.00,  "b": 1.00  },
    "WT":      { "r": 1.00,  "g": 1.00,  "b": 1.00  },
    "TH":      { "r": 0.09,  "g": 0.10,  "b": 0.14  },
    "BD":      { "r": 0.32,  "g": 0.35,  "b": 0.40  },
    "MT":      { "r": 0.55,  "g": 0.58,  "b": 0.65  },
    "BL":      { "r": 0.20,  "g": 0.40,  "b": 1.00  },
    "TL":      { "r": 0.08,  "g": 0.72,  "b": 0.65  },
    "STK":     { "r": 0.88,  "g": 0.89,  "b": 0.91  },
    "RL":      { "r": 0.85,  "g": 0.87,  "b": 0.89  },
    "WARN":    { "r": 0.90,  "g": 0.55,  "b": 0.10  },
    "ERR":     { "r": 0.85,  "g": 0.25,  "b": 0.25  },
    "SUCCESS": { "r": 0.15,  "g": 0.65,  "b": 0.40  }
  },

  "type": {
    "h1":    { "fontSize": 42, "style": "Bold",      "lineHeight": 52 },
    "h2":    { "fontSize": 28, "style": "Bold",      "lineHeight": 36 },
    "h3":    { "fontSize": 20, "style": "Semi Bold", "lineHeight": 28 },
    "h4":    { "fontSize": 16, "style": "Semi Bold", "lineHeight": 22 },
    "body":  { "fontSize": 14, "style": "Regular",   "lineHeight": 22 },
    "small": { "fontSize": 11, "style": "Regular",   "lineHeight": 17 },
    "label": { "fontSize": 10, "style": "Medium",    "lineHeight": null },
    "mono":  { "fontSize": 10, "style": "Medium",    "lineHeight": null, "family": "Geist Mono" }
  },

  "fonts": {
    "heading": "Inter",
    "body":    "Inter",
    "mono":    "Geist Mono",
    "weights": ["Bold", "Semi Bold", "Medium", "Regular", "Light"]
  },

  "effects": {
    "glass": {
      "subtle":  { "r": 16, "f": 0.60, "s": 0.15, "ga": 0.04, "bl": 16 },
      "default": { "r": 20, "f": 0.70, "s": 0.20, "ga": 0.06, "bl": 20 },
      "strong":  { "r": 24, "f": 0.80, "s": 0.25, "ga": 0.08, "bl": 24 }
    },
    "shadow": {
      "card":  { "type": "DROP_SHADOW", "color": { "r": 0.08, "g": 0.12, "b": 0.20, "a": 0.08 }, "offset": { "x": 0, "y": 2 }, "radius": 16, "spread": 0, "visible": true, "blendMode": "NORMAL" },
      "glow":  { "type": "DROP_SHADOW", "color": { "r": 0.20, "g": 0.40, "b": 1.00, "a": 0.08 }, "offset": { "x": 0, "y": 4 }, "radius": 20, "spread": 0, "visible": true, "blendMode": "NORMAL" }
    }
  },

  "spacing": {
    "page":    { "padding": 60, "gap": 16 },
    "card":    { "padding": 20, "gap": 10 },
    "slide":   { "width": 1080, "height": 1350, "padding": 80 },
    "frame16": { "width": 1920, "height": 1080 },
    "letter":  { "width": 1224, "height": 1584, "margin": 60 }
  },

  "gradients": {
    "accent": {
      "type": "GRADIENT_LINEAR",
      "gradientTransform": [[1,0,0],[0,1,0]],
      "gradientStops": [
        { "position": 0, "color": { "r": 0.20, "g": 0.40, "b": 1.00, "a": 1 } },
        { "position": 1, "color": { "r": 0.08, "g": 0.72, "b": 0.65, "a": 1 } }
      ]
    },
    "cta": {
      "type": "GRADIENT_LINEAR",
      "gradientTransform": [[1,0,0],[0,1,0]],
      "gradientStops": [
        { "position": 0, "color": { "r": 0.15, "g": 0.32, "b": 0.92, "a": 1 } },
        { "position": 1, "color": { "r": 0.06, "g": 0.50, "b": 0.60, "a": 1 } }
      ]
    }
  }
}
